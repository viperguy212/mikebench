# =============================================================================
# LLM API Hub — Environment Variables Template
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in every value marked with <REPLACE_THIS>
#   3. NEVER commit your .env file to git — it is listed in .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# AZURE GENERAL
# Your Azure Subscription ID — found in Azure Portal > Subscriptions
# -----------------------------------------------------------------------------
AZURE_SUBSCRIPTION_ID=<REPLACE_THIS>

# Your Azure Tenant ID — found in Azure Portal > Azure Active Directory > Overview
AZURE_TENANT_ID=<REPLACE_THIS>

# The Azure region where all resources will be deployed
# Recommended: eastus (cheapest + most available)
AZURE_LOCATION=eastus

# The name of your Resource Group (you will create this in Step 3)
AZURE_RESOURCE_GROUP=llm-api-hub-rg

# -----------------------------------------------------------------------------
# AZURE API MANAGEMENT (APIM)
# Created in Section 1 of the Azure Setup Guide
# -----------------------------------------------------------------------------
# The unique name you gave your APIM instance (must be globally unique)
APIM_SERVICE_NAME=<REPLACE_THIS>-llm-hub

# The APIM gateway URL — auto-generated after APIM creation
# Format: https://<your-apim-name>.azure-api.net
APIM_GATEWAY_URL=https://<REPLACE_THIS>.azure-api.net

# APIM Management API base URL — used by the backend to create users/subscriptions
APIM_MANAGEMENT_URL=https://management.azure.com/subscriptions/${AZURE_SUBSCRIPTION_ID}/resourceGroups/${AZURE_RESOURCE_GROUP}/providers/Microsoft.ApiManagement/service/${APIM_SERVICE_NAME}

# APIM Subscription Key for management operations
# Found in APIM > Security > Subscriptions > Built-in all-access subscription > Show keys
APIM_MASTER_SUBSCRIPTION_KEY=<REPLACE_THIS>

# -----------------------------------------------------------------------------
# AZURE AI FOUNDRY (LLM MODEL ENDPOINTS)
# Created in Section 1 — one entry per deployed model
# -----------------------------------------------------------------------------
# GPT-4o endpoint — found in AI Foundry > Deployments > gpt-4o > Endpoint
AI_FOUNDRY_GPT4O_ENDPOINT=https://<REPLACE_THIS>.openai.azure.com/
AI_FOUNDRY_GPT4O_KEY=<REPLACE_THIS>
AI_FOUNDRY_GPT4O_DEPLOYMENT_NAME=gpt-4o

# Mistral endpoint
AI_FOUNDRY_MISTRAL_ENDPOINT=https://<REPLACE_THIS>.services.ai.azure.com/models
AI_FOUNDRY_MISTRAL_KEY=<REPLACE_THIS>
AI_FOUNDRY_MISTRAL_DEPLOYMENT_NAME=mistral-large

# Meta Llama endpoint
AI_FOUNDRY_LLAMA_ENDPOINT=https://<REPLACE_THIS>.services.ai.azure.com/models
AI_FOUNDRY_LLAMA_KEY=<REPLACE_THIS>
AI_FOUNDRY_LLAMA_DEPLOYMENT_NAME=meta-llama-3-70b-instruct

# -----------------------------------------------------------------------------
# AZURE KEY VAULT
# Created in Section 1 — stores all secrets so they never appear in code
# -----------------------------------------------------------------------------
AZURE_KEY_VAULT_NAME=<REPLACE_THIS>-kv
AZURE_KEY_VAULT_URL=https://<REPLACE_THIS>-kv.vault.azure.net/

# -----------------------------------------------------------------------------
# AZURE ENTRA ID (App Registration for Admin Portal Auth)
# Created in Section 1 > App Registration
# -----------------------------------------------------------------------------
AZURE_AD_CLIENT_ID=<REPLACE_THIS>
AZURE_AD_CLIENT_SECRET=<REPLACE_THIS>
AZURE_AD_REDIRECT_URI=http://localhost:3001/auth/callback

# For frontend MSAL config
VITE_AZURE_AD_CLIENT_ID=<REPLACE_THIS>
VITE_AZURE_AD_TENANT_ID=<REPLACE_THIS>
VITE_AZURE_AD_REDIRECT_URI=http://localhost:5173

# -----------------------------------------------------------------------------
# AZURE COSMOS DB
# Created in Section 1 — stores consumer registrations and key metadata
# -----------------------------------------------------------------------------
COSMOS_DB_ENDPOINT=https://<REPLACE_THIS>.documents.azure.com:443/
COSMOS_DB_KEY=<REPLACE_THIS>
COSMOS_DB_DATABASE_NAME=llm-hub-db
COSMOS_DB_REGISTRATIONS_CONTAINER=registrations
COSMOS_DB_USAGE_CONTAINER=usage-logs

# -----------------------------------------------------------------------------
# AZURE COMMUNICATION SERVICES (Email)
# Created in Section 1 — sends welcome emails with API keys
# -----------------------------------------------------------------------------
ACS_CONNECTION_STRING=<REPLACE_THIS>
ACS_SENDER_ADDRESS=donotreply@<REPLACE_THIS>.azurecomm.net

# -----------------------------------------------------------------------------
# BACKEND SERVER CONFIG
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development

# JWT secret for session tokens — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<REPLACE_THIS>

# Admin email addresses — comma separated — these users can access the Admin panel
ADMIN_EMAILS=your-email@example.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# FRONTEND CONFIG (Vite environment variables — must start with VITE_)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:3001
VITE_APIM_GATEWAY_URL=https://<REPLACE_THIS>.azure-api.net
VITE_APP_NAME=LLM API Hub
