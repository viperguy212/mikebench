<!--
=============================================================================
GLOBAL APIM POLICY — applies to ALL APIs in this APIM instance
=============================================================================
WHAT THIS DOES:
  - Validates that every request has a valid subscription key
  - Adds standard security headers to every response
  - Configures CORS so your frontend can call the gateway
  - Formats all errors as consistent JSON
  - Logs request metadata for analytics

HOW TO APPLY:
  See apim-policies/README.md → "Apply the Global Policy"

🔐 SECURITY: The CORS policy below restricts calls to your frontend domain.
  Change <allowed-origins> to your production domain before going live.
  Using <origin>*</origin> allows any website to call your API — DO NOT do this.
=============================================================================
-->
<policies>
  <inbound>
    <!-- 
         CORS Policy
         Allows your frontend to call the APIM gateway from a browser.
         Replace https://your-app.azurestaticapps.net with your real frontend URL.
   -->
    <cors allow-credentials="false">
      <allowed-origins>
        <origin>http://localhost:5173</origin>
        <origin>https://your-app.azurestaticapps.net</origin>
      </allowed-origins>
      <allowed-methods>
        <method>GET</method>
        <method>POST</method>
        <method>OPTIONS</method>
      </allowed-methods>
      <allowed-headers>
        <header>Content-Type</header>
        <header>Authorization</header>
        <header>Ocp-Apim-Subscription-Key</header>
        <header>api-version</header>
      </allowed-headers>
    </cors>

    <!-- 
         Subscription Key Validation
         Rejects any request that does not include a valid APIM subscription key.
         The key is passed in the "Ocp-Apim-Subscription-Key" header.
         This is the primary access control mechanism.
   -->
    <!-- Subscription key validation is automatic in APIM when subscription-required=true on the Product -->
    <!-- This block adds a clear error message if the key is missing -->
    <choose>
      <when condition="@(context.Subscription == null)">
        <return-response>
          <set-status code="401" reason="Unauthorized" />
          <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
          </set-header>
          <set-body>@{
            return new JObject(
              new JProperty("error", new JObject(
                new JProperty("code", "MISSING_SUBSCRIPTION_KEY"),
                new JProperty("message", "A valid subscription key is required. Pass it in the 'Ocp-Apim-Subscription-Key' header. Get your key at https://your-developer-portal-url.developer.azure-api.net"),
                new JProperty("status", 401)
              ))
            ).ToString();
          }</set-body>
        </return-response>
      </when>
    </choose>

    <!-- 
         Add request tracking headers
         Adds a unique correlation ID to every request so you can
         trace a specific call through all your logs.
   -->
    <set-header name="X-Request-Id" exists-action="override">
      <value>@(Guid.NewGuid().ToString())</value>
    </set-header>
    <set-header name="X-Consumer-Id" exists-action="override">
      <value>@(context.Subscription?.Id ?? "anonymous")</value>
    </set-header>

    <base />
  </inbound>

  <backend>
    <base />
  </backend>

  <outbound>
    <!-- 
         Security Response Headers
         These headers protect consumers' browsers from common attacks.
         They are industry-standard and should always be set.
   -->
    <set-header name="X-Content-Type-Options" exists-action="override">
      <value>nosniff</value>
    </set-header>
    <set-header name="X-Frame-Options" exists-action="override">
      <value>DENY</value>
    </set-header>
    <set-header name="Strict-Transport-Security" exists-action="override">
      <value>max-age=31536000; includeSubDomains</value>
    </set-header>

    <!-- Remove server identification headers for security -->
    <set-header name="X-Powered-By" exists-action="delete" />
    <set-header name="Server" exists-action="delete" />

    <base />
  </outbound>

  <on-error>
    <!-- 
         Global Error Handler
         Formats all unhandled errors as consistent JSON responses
         instead of the default APIM XML error format.
   -->
    <set-header name="Content-Type" exists-action="override">
      <value>application/json</value>
    </set-header>
    <set-body>@{
      return new JObject(
        new JProperty("error", new JObject(
          new JProperty("code", context.LastError.Reason),
          new JProperty("message", context.LastError.Message),
          new JProperty("status", context.Response.StatusCode),
          new JProperty("requestId", context.RequestId)
        ))
      ).ToString();
    }</set-body>
    <base />
  </on-error>
</policies>
