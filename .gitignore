# =============================================================================
# .gitignore — Never commit these files
# =============================================================================

# Environment variables — NEVER commit these (contain secrets)
.env
.env.local
.env.production

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
.next/
out/

# VS Code
.vscode/
*.code-workspace

# OS files
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Azure
.azure/

# Test coverage
coverage/
